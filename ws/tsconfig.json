{
  "compilerOptions": {
    "target": "ESNext",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "src",
    "outDir": "dist",

    "strict": true,

    "types": ["node"],

    "skipLibCheck": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "resolveJsonModule": true,

    "verbatimModuleSyntax": false
  },
  "include": ["src"]
}